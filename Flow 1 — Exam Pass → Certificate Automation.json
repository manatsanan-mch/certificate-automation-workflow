    {
      "parameters": {
        "html": "<div style=\"width:800px; height:600px; padding:20px; text-align:center; background-color: #ffffff; font-family: 'Sarabun', 'Helvetica Neue', Helvetica, Arial, sans-serif; position: relative; box-sizing: border-box;\">\n\n    <div style=\"width:100%; height:100%; border: 20px solid #1A237E; box-sizing: border-box; position: relative; display: flex; flex-direction: column; justify-content: center; align-items: center;\">\n        \n        <div style=\"width:95%; height:95%; border: 2px solid #D4AF37; box-sizing: border-box; position: absolute; top: 2.5%; left: 2.5%;\"></div>\n\n        <div style=\"z-index: 2; width: 80%;\">\n            \n            <h1 style=\"color: #1A237E; font-size:48px; margin: 0 0 10px 0; text-transform: uppercase; letter-spacing: 3px;\">\n                ใบประกาศนียบัตร\n            </h1>\n            \n            <p style=\"font-size:18px; color: #757575; margin-bottom: 30px; letter-spacing: 1px;\">\n                ขอมอบรางวัลนี้เพื่อแสดงว่า\n            </p>\n            \n            <h2 style=\"font-size:60px; color: #D4AF37; margin: 20px 0; font-family: 'Times New Roman', serif; font-weight: bold; border-bottom: 1px solid #eee; display: inline-block; padding: 0 40px 10px 40px;\">\n                {{ $('Watch Google Sheets').item.json[\"กรอก \\\"ชื่อเล่น\\\"\"] }}\n            </h2>\n            \n            <p style=\"font-size:20px; color: #333333; margin-top: 30px;\">\n                ได้ผ่านการทดสอบความรู้เป็นที่เรียบร้อยแล้ว\n            </p>\n\n            <div style=\"margin-top: 40px; display: flex; justify-content: center; gap: 50px;\">\n                <div style=\"text-align: center;\">\n                    <span style=\"display: block; font-size: 14px; color: #999; text-transform: uppercase;\">คะแนนที่ได้</span>\n                    <span style=\"font-size: 28px; color: #1A237E; font-weight: bold;\">\n                        {{ $('Watch Google Sheets').item.json[\"คะแนน\"] }}\n                    </span>\n                </div>\n                \n                <div style=\"width: 1px; height: 50px; background-color: #ddd;\"></div> <div style=\"text-align: center;\">\n                    <span style=\"display: block; font-size: 14px; color: #999; text-transform: uppercase;\">วันที่อนุมัติ</span>\n                    <span style=\"font-size: 28px; color: #1A237E;\">\n                        {{ $('Format Certificate Date').item.json[\"formatted_date\"] }}\n                    </span>\n                </div>\n            </div>\n\n        </div>\n\n        <div style=\"position: absolute; bottom: 30px; width: 100%; text-align: center;\">\n             <p style=\"font-size:12px; color: #BDBDBD; margin: 0; letter-spacing: 1px;\">\n                Certificate ID: <span style=\"font-family: monospace;\">{{ $('Generate Certificate ID').item.json[\"cert_id\"] }}</span>\n            </p>\n        </div>\n\n        <div style=\"position: absolute; bottom: 40px; right: 40px; width: 80px; height: 80px; border: 3px solid #D4AF37; border-radius: 50%; display: flex; align-items: center; justify-content: center; opacity: 0.3; transform: rotate(-15deg);\">\n            <span style=\"color: #D4AF37; font-size: 12px; font-weight: bold; text-align: center;\">OFFICIAL<br>APPROVED</span>\n        </div>\n\n    </div>\n</div>"
      },

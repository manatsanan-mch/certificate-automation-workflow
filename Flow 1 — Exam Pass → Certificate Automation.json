    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. ดึงชื่อเล่นจากโหนด Watch Google Sheets\n// (สำคัญ: ต้องพิมพ์ชื่อโหนดให้ตรงกับใน Flow ของคุณเป๊ะๆ)\nlet userName = $('Watch Google Sheets').item.json['กรอก \"ชื่อเล่น\"'];\n\n// กรณีกันเหนียว: ถ้าหาชื่อไม่เจอ ให้ใช้ชื่อว่า certificate แทน\nif (!userName) {\n  userName = 'certificate';\n}\n\n// 2. ดึงเนื้อหา HTML\nconst htmlContent = item.json.html;\n\nif (htmlContent) {\n  // 3. สร้างไฟล์โดยใช้ชื่อจากตัวแปร userName\n  item.binary = {\n    data: {\n      data: Buffer.from(htmlContent).toString('base64'),\n      mimeType: 'text/html',\n      \n      // ตรงนี้ครับที่เปลี่ยนชื่อไฟล์ (เช่น \"โอปอ.html\")\n      fileName: userName + '.html', \n      \n      fileExtension: 'html'\n    }\n  };\n}\n\nreturn item;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
